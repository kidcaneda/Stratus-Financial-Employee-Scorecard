rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function isAdmin() { return signedIn() && role() == 'admin'; }
    // Managers and supervisors are the same privilege tier: department
    // leads who score the employees reporting to them.
    function isLead() { return signedIn() && (role() == 'manager' || role() == 'supervisor'); }

    // The departments a lead is assigned to (from assignments/{uid}).
    function assignedDepts() {
      return get(/databases/$(database)/documents/assignments/$(request.auth.uid)).data.departmentIds;
    }
    function managesDept(deptId) {
      return isLead() && deptId in assignedDepts();
    }
    // Direct-report link: the employee record names this lead as evaluator.
    function evaluates(deptId, employeeId) {
      return isLead() &&
        get(/databases/$(database)/documents/departments/$(deptId)/employees/$(employeeId)).data.evaluatorUid == request.auth.uid;
    }

    // users/{uid} — own profile read; admin full.
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // assignments/{uid} — manager→department map. Read own or admin; write admin only.
    match /assignments/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // departments/{id} — read for all signed-in; template writes admin only.
    match /departments/{deptId} {
      allow read: if signedIn();
      allow write: if isAdmin();

      match /metrics/{metricId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }

      // employees subcollection — leads may write to THEIR departments or
      // THEIR direct reports, admins to any. Core Phase B write permission.
      match /employees/{employeeId} {
        allow read: if signedIn();
        allow create: if isAdmin() || managesDept(deptId);
        allow update: if isAdmin() || managesDept(deptId)
          || (isLead() && resource.data.evaluatorUid == request.auth.uid);
        allow delete: if isAdmin();

        // months subcollection (Phase C/D) — dated monthly evaluations.
        // Direct client writes are restricted to managers/admins for SCORE
        // entry. Employee acknowledge/dispute does NOT write directly from
        // the client — it goes through /api/acknowledge, which uses the
        // Admin SDK (bypassing these rules) AFTER verifying the employee
        // owns the record (linkedUid). This keeps the client rule strict.
        match /months/{monthKey} {
          allow read: if signedIn();
          allow create, update: if isAdmin() || managesDept(deptId)
            || evaluates(deptId, employeeId);
          allow delete: if isAdmin();
        }
      }
    }

    // Collection-group reads power the "My Team" direct-report query
    // (collectionGroup('employees').where('evaluatorUid', '==', uid)).
    // Same visibility as the nested rule above: any signed-in user.
    match /{path=**}/employees/{employeeId} {
      allow read: if signedIn();
    }

    // audit/{id} — append-only trail. Anyone signed in may create (the
    // server route writes these); NOBODY may update or delete. Admins read.
    match /audit/{entryId} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // config/* — thresholds/settings. Read all signed in; write admin.
    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // NOTE: The Firebase Admin SDK (server routes) bypasses these rules,
    // which is why privileged writes happen server-side with verification.
  }
}
